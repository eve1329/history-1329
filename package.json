{
  "name": "codex-history-viewer",
  "version": "1.2.5",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "test:provider-config": "node scripts/test-provider-config.mjs",
    "test:windows-regressions": "node scripts/test-windows-path-and-rollout.mjs",
    "build:mac": "bash mac/build-mac-app.sh",
    "release:mac": "MAC_RUNTIME=darwin-arm64 bash scripts/release-mac.sh",
    "release:mac:arm64": "MAC_RUNTIME=darwin-arm64 bash scripts/release-mac.sh",
    "release:mac:x64": "MAC_RUNTIME=darwin-x64 bash scripts/release-mac.sh",
    "build:win": "powershell -ExecutionPolicy Bypass -File win/build-windows.ps1",
    "build:win:arm64": "powershell -ExecutionPolicy Bypass -File win/build-windows.ps1 -Runtime win-arm64",
    "license:keygen": "node scripts/generate-license-keypair.mjs",
    "license:server": "node license-server.mjs"
  }
}
